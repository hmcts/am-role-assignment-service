{
  "_guid_": "S-025.06_CreateOrgRoles_JUDICIAL",
  "_extends_": "F-025_CreateOrgRoles__Base",

  "specs": [
    "to create org role assignments for actor (JUDICIAL) & requester (case-allocator)"
  ],

  "request": {
    "body": {
      "requestedRoles": [
        {
          "actorIdType": "IDAM",
          "actorId": "${[scenarioContext][testData][users][befta3][id]}",
          "roleName": "circuit-judge",
          "roleCategory": "JUDICIAL",
          "roleType": "ORGANISATION",
          "grantType": "STANDARD",
          "classification": "PUBLIC",
          "readOnly": false,
          "beginTime": "${[scenarioContext][customValues][today]}T00:00:00Z",
          "endTime": "${[scenarioContext][customValues][tomorrow]}T00:00:00Z",
          "attributes": {
            "jurisdiction": "CIVIL",
            "primaryLocation": "123456"
          }
        }
      ]
    }
