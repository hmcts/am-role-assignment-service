{
  "_guid_": "S-023.03_Org_Role_Creation",
  "_extends_": "F-023_CreateOrgRoles__Base",

  "specs": [
    "to create CTSC org role assignments for actor"
  ],

  "request": {
    "body": {
      "requestedRoles": [
        {
          "actorIdType": "IDAM",
          "actorId": "${[scenarioContext][testData][users][invokingUser][id]}",
          "roleName": "ctsc",
          "roleCategory": "CTSC",
          "roleType": "ORGANISATION",
          "grantType": "STANDARD",
          "classification": "PUBLIC",
          "readOnly": false,
          "beginTime": "${[scenarioContext][customValues][today]}T00:00:00Z",
          "endTime": "${[scenarioContext][customValues][tomorrow]}T00:00:00Z",
          "attributes": {
            "jurisdiction": "PCS",
            "primaryLocation": "123456",
            "region": "2"
          }
        }
      ]
    }
  },

  "expectedResponse": {
    "body": {
      "roleAssignmentResponse": {
        "requestedRoles": [
          {
