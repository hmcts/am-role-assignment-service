{
  "title": "must successfully create allocated-wlu-caseworker POSSESSIONS case wlu-team-leader",
  "_guid_": "S-022.10a",
  "_extends_": "F-022_Test_Data_Base",
  "specs": [
    "contains ReplaceExisting is false and reference set to caseId",
    "Befta3 - who is the actor for requested role",
    "contains wlu-team-leader case role assignment"
  ],
  "users": {
    "invokingUser": {
      "_extends_": "AmBeftaUser4"
    }
  },
  "request": {
    "body": {
      "roleRequest": {
        "assignerId": "${[scenarioContext][testData][users][invokingUser][id]}",
        "reference": "1776251462396879/allocated-wlu-caseworker"
      },
      "requestedRoles": [
        {
          "_extends_": "RequestedRole",
          "actorId": "${[scenarioContext][testData][users][befta3][id]}",
          "roleName": "allocated-wlu-caseworker",
          "roleCategory": "ADMIN",
          "roleType": "CASE",
          "grantType": "SPECIFIC",
          "classification": "RESTRICTED",
          "attributes":
          {
            "caseId" : "1776251462396879",
            "jurisdiction": "PCS",
            "caseType": "[[ANYTHING_PRESENT]]"
          }
        }
      ]
    }
  },
  "expectedResponse": {
    "_extends_": "Common_201_Response",
    "headers": {
      "Content-Length": "[[ANYTHING_PRESENT]]",
      "Content-Type": "application/json"
    },
    "body": {
      "roleAssignmentResponse": {
        "roleRequest": {
          "_extends_": "ResponseRoleRequest",
          "reference": "${[scenarioContext][testData][request][body][roleRequest][reference]}",
          "status": "APPROVED",
          "replaceExisting": true
        },
        "requestedRoles": [
          {
            "_extends_": "ResponseRequestedRole",
            "actorId": "${[scenarioContext][testData][users][befta3][id]}",
            "process" : "[[ANYTHING_PRESENT]]",
            "roleName": "${[scenarioContext][testData][request][body][requestedRoles][0][roleName]}",
            "roleCategory": "${[scenarioContext][testData][request][body][requestedRoles][0][roleCategory]}",
            "roleType": "${[scenarioContext][testData][request][body][requestedRoles][0][roleType]}",
            "grantType": "${[scenarioContext][testData][request][body][requestedRoles][0][grantType]}",
            "status": "LIVE",
            "attributes":
            {
              "caseId" : "${[scenarioContext][testData][request][body][requestedRoles][0][attributes][caseId]}",
              "jurisdiction" : "${[scenarioContext][testData][request][body][requestedRoles][0][attributes][jurisdiction]}",
              "caseType" : "${[scenarioContext][testData][request][body][requestedRoles][0][attributes][caseType]}",
              "substantive": "Y"
            }
          }
        ]
      }
    }
  }
}
